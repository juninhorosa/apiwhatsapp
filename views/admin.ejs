<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Painel Admin - WhatsApp SaaS</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-100 min-h-screen">
    <nav class="bg-blue-800 p-4 text-white flex justify-between items-center shadow-md">
        <h1 class="text-xl font-bold">Admin Panel</h1>
        <div class="flex items-center space-x-4">
            <a href="/dashboard" class="text-sm hover:underline">Ir para Dashboard</a>
            <a href="/auth/logout" class="bg-red-500 hover:bg-red-700 text-white py-1 px-4 rounded text-sm">Sair</a>
        </div>
    </nav>

    <div class="max-w-6xl mx-auto mt-10 p-6 bg-white rounded-lg shadow-md">
        <!-- Stats Section -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-10">
            <div class="bg-blue-50 p-6 rounded-xl border border-blue-100">
                <p class="text-sm text-blue-600 font-bold uppercase mb-1">Total de Usuários</p>
                <p class="text-3xl font-extrabold text-blue-900"><%= stats.totalUsers %></p>
            </div>
            <div class="bg-green-50 p-6 rounded-xl border border-green-100">
                <p class="text-sm text-green-600 font-bold uppercase mb-1">Mensagens Enviadas</p>
                <p class="text-3xl font-extrabold text-green-900"><%= stats.totalMessages %></p>
            </div>
            <div class="bg-yellow-50 p-6 rounded-xl border border-yellow-100">
                <p class="text-sm text-yellow-600 font-bold uppercase mb-1">Assinantes Premium</p>
                <p class="text-3xl font-extrabold text-yellow-900"><%= stats.premiumUsers %></p>
            </div>
        </div>

        <div class="bg-gray-50 p-6 rounded-xl border border-gray-200 mb-10">
            <h2 class="text-2xl font-bold mb-6">Status do Servidor</h2>
            <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Host</p>
                    <p class="text-sm font-semibold text-gray-900"><%= system.hostname %></p>
                    <p class="text-xs text-gray-500 mt-1"><%= system.platform %></p>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Uptime</p>
                    <p class="text-sm font-semibold text-gray-900">Servidor: <%= system.serverUptime %></p>
                    <p class="text-xs text-gray-500 mt-1">Processo: <%= system.processUptime %></p>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Carga</p>
                    <p class="text-sm font-semibold text-gray-900"><%= system.loadAvg %></p>
                    <p class="text-xs text-gray-500 mt-1">Node: <%= system.node %></p>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Memória (Host)</p>
                    <p class="text-sm font-semibold text-gray-900"><%= system.memFreeMB %> MB livre</p>
                    <p class="text-xs text-gray-500 mt-1"><%= system.memTotalMB %> MB total</p>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Memória (App)</p>
                    <p class="text-sm font-semibold text-gray-900">RSS: <%= system.rssMB %> MB</p>
                    <p class="text-xs text-gray-500 mt-1">Heap: <%= system.heapUsedMB %> MB</p>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">Serviços</p>
                    <p class="text-sm font-semibold text-gray-900">MongoDB: <%= system.mongoState %></p>
                    <p class="text-xs text-gray-500 mt-1">Sessões WhatsApp (RAM): <%= system.waSessionsInMemory %></p>
                    <p class="text-xs text-gray-500 mt-1">Fila: <%= system.queuePending %> pendentes / <%= system.queueUsers %> usuários</p>
                    <p class="text-xs text-gray-500 mt-1">Delay fila: <%= system.queueDelayMs %>ms | Máx/usuário: <%= system.queueMaxPerUser %></p>
                </div>
            </div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-2">Segurança (App)</p>
                    <div class="text-sm text-gray-800 space-y-1">
                        <div>Helmet: <span class="font-semibold"><%= security.helmet ? 'ativo' : 'inativo' %></span></div>
                        <div>Rate limit (/auth): <span class="font-semibold"><%= security.rateLimit.max %></span> req / <span class="font-semibold"><%= security.rateLimit.windowMinutes %></span> min</div>
                        <div>CORS methods: <span class="font-semibold"><%= security.cors.methods.join(', ') %></span></div>
                        <div>CORS headers: <span class="font-semibold"><%= security.cors.allowedHeaders.join(', ') %></span></div>
                        <div>trust proxy: <span class="font-semibold"><%= security.trustProxy ? 'sim' : 'não' %></span></div>
                    </div>
                </div>
                <div class="bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-2">Melhorias (Recomendado)</p>
                    <div class="text-sm text-gray-800 space-y-1">
                        <div>Use domínio + HTTPS para integrações em sites HTTPS.</div>
                        <div>Restrinja IPs no Oracle (Ingress) quando possível.</div>
                        <div>Use chaves SSH e desative login por senha no servidor.</div>
                        <div>Ative fail2ban/limites no SSH para evitar brute force.</div>
                        <div>Monitore CPU/RAM e reinicie containers em loops.</div>
                    </div>
                </div>
            </div>

            <% if (system.publicBaseUrl) { %>
                <div class="mt-6 bg-white p-4 rounded-lg border">
                    <p class="text-xs text-gray-500 uppercase font-bold mb-1">PUBLIC_BASE_URL</p>
                    <p class="text-sm font-semibold text-gray-900 break-all"><%= system.publicBaseUrl %></p>
                </div>
            <% } %>
        </div>

        <h2 class="text-2xl font-bold mb-6">Gerenciamento de Usuários</h2>
        
        <div class="overflow-x-auto">
            <table class="min-w-full bg-white">
                <thead class="bg-gray-800 text-white">
                    <tr>
                        <th class="py-3 px-4 text-left">Nome</th>
                        <th class="py-3 px-4 text-left">Email</th>
                        <th class="py-3 px-4 text-left">Plano</th>
                        <th class="py-3 px-4 text-left">Uso Hoje</th>
                        <th class="py-3 px-4 text-left">Status</th>
                        <th class="py-3 px-4 text-left">Ações</th>
                    </tr>
                </thead>
                <tbody class="text-gray-700">
                    <% users.forEach(user => { %>
                    <tr class="border-b">
                        <td class="py-3 px-4"><%= user.name %></td>
                        <td class="py-3 px-4"><%= user.email %></td>
                        <td class="py-3 px-4">
                            <span class="px-2 py-1 rounded text-xs font-bold <%= user.plan === 'premium' ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
                                <%= user.plan %>
                            </span>
                        </td>
                        <td class="py-3 px-4 text-sm"><%= user.messagesSentToday %> / <%= user.dailyLimit %></td>
                        <td class="py-3 px-4">
                            <span class="px-2 py-1 rounded text-xs font-bold <%= user.status === 'active' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800' %>">
                                <%= user.status %>
                            </span>
                        </td>
                        <td class="py-3 px-4 flex space-x-2">
                            <button onclick="updateUser('<%= user._id %>', { plan: '<%= user.plan === 'premium' ? 'free' : 'premium' %>' })" class="text-xs bg-blue-500 hover:bg-blue-600 text-white py-1 px-2 rounded">
                                <%= user.plan === 'premium' ? 'Tornar Free' : 'Tornar Premium' %>
                            </button>
                            <button onclick="updateUser('<%= user._id %>', { status: '<%= user.status === 'active' ? 'blocked' : 'active' %>' })" class="text-xs <%= user.status === 'active' ? 'bg-red-500 hover:bg-red-600' : 'bg-green-500 hover:bg-green-600' %> text-white py-1 px-2 rounded">
                                <%= user.status === 'active' ? 'Bloquear' : 'Desbloquear' %>
                            </button>
                        </td>
                    </tr>
                    <% }) %>
                </tbody>
            </table>
        </div>
    </div>

    <script>
        async function updateUser(userId, data) {
            if (confirm('Deseja realmente atualizar este usuário?')) {
                const res = await fetch(`/admin/users/${userId}`, {
                    method: 'PATCH',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });
                const result = await res.json();
                if (result.success) {
                    location.reload();
                } else {
                    alert(result.error);
                }
            }
        }
    </script>
</body>
</html>
